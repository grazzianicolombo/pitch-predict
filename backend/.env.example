# ─────────────────────────────────────────────────────────────────────────────
# pitch-predict — Backend Environment Variables
#
# NÃO preencha este arquivo com valores reais.
# Todas as variáveis são gerenciadas pelo Doppler:
#   https://dashboard.doppler.com → projeto: pitch-predict
#
#   Dev local  →  doppler run -- npm run dev
#   Produção   →  apenas DOPPLER_TOKEN no Railway; o app busca o resto via CLI
# ─────────────────────────────────────────────────────────────────────────────

# Servidor
PORT=3001

# Supabase
SUPABASE_URL=https://<project-id>.supabase.co
SUPABASE_KEY=<anon-key>          # Usado para operações MFA com sessão do usuário
SUPABASE_SERVICE_KEY=<service-role-key>  # Acesso admin (bypassa RLS)

# CORS — URL exata do frontend em produção
ALLOWED_ORIGINS=https://<seu-app>.vercel.app

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# Tavily Search
TAVILY_API_KEY=tvly-...

# People Data Labs
PDL_API_KEY=<pdl-key>

# Email (Gmail App Password — https://myaccount.google.com/apppasswords)
SMTP_USER=<gmail>
SMTP_PASS=<app-password>
